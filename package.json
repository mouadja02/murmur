{
  "name": "murmur",
  "version": "0.0.0",
  "description": "Voice-first prompt engineering for vibe coders. Phase 0 spike.",
  "private": true,
  "type": "module",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "tsc && electron .",
    "build": "tsc",
    "check": "tsc --noEmit && biome check .",
    "format": "biome format --write .",
    "setup:whisper": "powershell -ExecutionPolicy Bypass -File ./scripts/setup-whisper.ps1"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@types/node": "^25.6.0",
    "dotenv": "^17.4.2",
    "electron": "^41.2.1",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@nut-tree-fork/nut-js": "^4.2.6",
    "uiohook-napi": "^1.5.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "uiohook-napi"
    ]
  }
}
