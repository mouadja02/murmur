# Murmur env vars (legacy / dev convenience).
# Anything here is overridden by --flags and by %APPDATA%/murmur/config.json.
# See README.md for the full schema and CLI flags.

# LLM provider: ollama | openai-compat | anthropic
LLM_PROVIDER=ollama

# Provider HTTP base URL. For openai-compat, include the /v1 segment.
#   Ollama:           http://localhost:11434
#   LM Studio:        http://localhost:1234/v1
#   llama.cpp server: http://localhost:8080/v1
#   Anthropic:        https://api.anthropic.com/v1
LLM_BASE_URL=http://localhost:11434

# Model id on the provider.
LLM_MODEL=qwen3:4b

# Optional bearer token for openai-compat; required for Anthropic.
# LLM_API_KEY=

# Sampling temperature.
# LLM_TEMPERATURE=0.2

# Local whisper.cpp paths (run `pnpm setup:whisper` to populate ./bin/whisper).
WHISPER_CLI_PATH=./bin/whisper/whisper-cli.exe
WHISPER_MODEL_PATH=./bin/whisper/models/ggml-base.en.bin

# Per-session log dir override.
# MURMUR_LOGS_DIR=./logs

# Hotkey overrides. Combos parse from "Ctrl+Shift+Space" form, modifiers
# accept Ctrl/Control, Shift, Alt/Option, Cmd/Win/Meta/Super.
# MURMUR_HOTKEY=Ctrl+Shift+Space
# MURMUR_TOGGLE_HOTKEY=Ctrl+Shift+H
